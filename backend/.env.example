# ─────────────────────────────────────────────
# PST Scheduler — Backend Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub!
# ─────────────────────────────────────────────

# PostgreSQL connection string
# Local example:    postgresql://postgres:yourpassword@localhost:5432/pst_scheduler
# Railway example:  postgresql://postgres:xxxx@containers-us-west-xxx.railway.app:5432/railway
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/pst_scheduler

# JWT secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_string_at_least_64_chars

# Server port
PORT=4000

# Frontend URL (for CORS — update to your Vercel URL in production)
FRONTEND_URL=http://localhost:5173

# Node environment: development | production
NODE_ENV=development
